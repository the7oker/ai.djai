# Database Configuration
POSTGRES_DB=music_ai
POSTGRES_USER=musicai
POSTGRES_PASSWORD=changeme_secure_password

# Music Library Path
# Windows: E:\Music
# Linux: /path/to/music
MUSIC_LIBRARY_PATH=E:\Music

# API Keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# GPU Configuration
# Specify which GPU to use (0 for first GPU, 1 for second, etc.)
CUDA_VISIBLE_DEVICES=0

# Application Settings
LOG_LEVEL=INFO

# Optional: External API Keys (for Phase 2)
# Spotify removed (deprecated API - Nov 2024)
LASTFM_API_KEY=your_lastfm_api_key

# HQPlayer Integration (Phase 3.2)
# For WSL2: Use Windows host IP (get with: ip route show | grep default)
# For Docker: Use host.docker.internal or Windows host IP
HQPLAYER_HOST=localhost
HQPLAYER_PORT=4321
HQPLAYER_ENABLED=false

# Claude Code integration (agent-based AI DJ instead of RAG)
# Requires: Claude Code CLI in Docker, OAuth credentials mounted at ~/.claude/.credentials.json
CLAUDE_CODE_ENABLED=false
