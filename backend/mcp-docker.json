{
  "mcpServers": {
    "postgres": {
      "command": "npx",
      "args": ["-y", "@anthropic-ai/postgres-mcp-server", "postgresql://musicai:supervisor@postgres:5432/music_ai"],
      "env": {}
    },
    "hqplayer": {
      "command": "python3",
      "args": ["/app/mcp/hqplayer_server.py"],
      "env": {
        "DB_HOST": "postgres",
        "DB_PORT": "5432",
        "DB_USER": "musicai",
        "DB_PASSWORD": "supervisor",
        "DB_NAME": "music_ai",
        "HQPLAYER_HOST": "host.docker.internal",
        "HQPLAYER_PORT": "4321",
        "MUSIC_WINDOWS_PATH": "E:/Music",
        "BACKEND_URL": "http://localhost:8000",
        "TRACKER_URL": "http://playback-tracker:8765",
        "BACKEND_PATH": "/app"
      }
    }
  }
}
